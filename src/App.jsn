import React, { useState, useEffect, useRef, createContext, useContext } from "react";
// ─── STORAGE ──────────────────────────────────────────────────────────────────

const KEY = "ironlog_v2";

function load() {
  try {
    const raw = localStorage.getItem(KEY);
    if (!raw) return { programs: [], activeProgId: null, logs: [] };
    const d = JSON.parse(raw);
    if (d.program && !d.programs) {
      return { programs: [{ ...d.program, id: "migrated" }], activeProgId: "migrated", logs: d.logs || [] };
    }
    return d;
  } catch { return { programs: [], activeProgId: null, logs: [] }; }
}
function persist(d) { localStorage.setItem(KEY, JSON.stringify(d)); }


